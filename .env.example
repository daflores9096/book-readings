# Copiar a .env: copy .env.example .env (Windows) o cp .env.example .env

WEB_PORT=18081
APP_URL=http://localhost:18081

MYSQL_DATABASE=book_readings_db
MYSQL_USER=book_user
MYSQL_PASSWORD=book_password
MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_PORT=3306 # usar con docker-compose.db-port.yml

JWT_SECRET=super_secret_key_123
JWT_TTL=3600
APP_ENV=development
APP_DEBUG=true

# Vite dev (npm run dev en frontend/)
VITE_DEV_API_PROXY=http://127.0.0.1:18081

# phpMyAdmin opcional (docker-compose.phpmyadmin.yml)
PMA_PORT=8082
