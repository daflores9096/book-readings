{
  "name": "book-readings/backend",
  "description": "Backend PHP para registro de lecturas con MySQL y JWT",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "require": {
    "php": ">=8.2",
    "firebase/php-jwt": "^6.0",
    "vlucas/phpdotenv": "^5.5",
    "ext-json": "*",
    "ext-gd": "*",
    "ext-pdo": "*"
  },
  "config": {
    "audit": {
      "block-insecure": false
    }
  }
}
